#!/bin/bash
# Author: Christos Deligkaris (rewritten to use a shared conda environment)
# Date: December 2022, revised 2026
# Purpose: Submit a Microsim python job to the Ohio Supercomputer Center.
# Note: This version uses a SHARED conda environment that lives in PAS2139
#       project space, following OSC's recommended practice. No poetry, no
#       per-user virtual environment, no copying of the environment to $TMPDIR.

# ---- configurable locations (override via environment if desired) ----
# The shared conda environment, built once with:
#   conda create --prefix /fs/ess/PAS2139/envs/microsim python=3.12 <deps...>
condaEnv="${MICROSIM_ENV:-/fs/ess/PAS2139/envs/microsim}"
# The microsim source tree (poetry expects to run from inside it).
microsimDir="${MICROSIM_DIR:-/fs/ess/PAS2139/christos/MICROSIM/CODE/microsim}"
# The miniconda3 module that provides the 'conda' command.
# Confirm the exact name on your cluster with:  module spider miniconda3
condaModule="${MICROSIM_CONDA_MODULE:-miniconda3/24.1.2-py310}"

# ---- Slurm default arguments ----
defaultWalltime="--time=1:00:00"
defaultNtasks="--ntasks-per-node=1"
defaultNodes="--nodes=1"
defaultAccount="--account=PAS2139"

# ---- check the arguments ----
if [ $# -lt 1 ]; then
        echo $'\nERROR: you need at least one argument (the input file)....\n'
        echo $'USAGE: submic yourPythonFile.py yourSlurmArguments\n'
        echo $"Slurm default arguments: $defaultWalltime $defaultNtasks $defaultNodes $defaultAccount"
        exit
fi
inputFile="$1"

# input file must be a .py file
if [[ $inputFile != *.py ]] ; then
        echo $'\nERROR: input file is not a .py file\n'
        exit
fi

# input file must exist and be readable
if [ ! -f "$inputFile" ] || [ ! -r "$inputFile" ] ; then
        echo $"\nERROR: cannot find or read input file \"${inputFile}\"\n"
        exit
fi

outputFile="${1%.py}".log
jobname=$(echo "$inputFile" | awk '{print substr($0,1,15)}')

# ---- pass through any sbatch arguments ----
sbatch_arg=
for arg in $@; do
        if [ $arg != $0 ] && [ $arg != $1 ] ; then
                sbatch_arg="$sbatch_arg $arg"
        fi
done

# CPU/memory binding (unchanged)
export SLURM_CPU_BIND="cores"
export SLURM_MEM_BIND="local"
export SLURM_DISTRIBUTION="block:block"

# ---- submit the SLURM job ----
sbatch ${sbatch_arg} << EOF
#!/bin/bash
#SBATCH --job-name=$jobname
#SBATCH -e stderr.txt
#SBATCH -o stdout.txt
#SBATCH --export=ALL
#SBATCH --account=PAS2139
#SBATCH --ntasks-per-node=1
#SBATCH --nodes=1
#SBATCH --time=1:00:00

date
startTime=\$SECONDS
echo "setup starts now..."

# Work on the node's fast local disk.
cd \$TMPDIR

# Copy the job's input files (the .py and anything alongside it) to the node.
cp \$SLURM_SUBMIT_DIR/* ./

# ---- environment setup (OSC recommended sequence) ----
# Clear any environment inherited from the submitting shell, reset modules,
# then load conda and activate the SHARED project-space environment in place.
source deactivate 2>/dev/null    # harmless if nothing is active
module reset
module load $condaModule
module list

# Keep packages from ~/.local out of the environment (OSC best practice).
export PYTHONNOUSERSITE=True

# Activate the shared env by absolute path. Use 'source activate', NOT
# 'conda activate' (the latter tries to edit your shell rc file).
source activate $condaEnv

# Make the microsim package itself importable. The conda env contains only
# microsim's DEPENDENCIES; the package source lives in the repo tree. Adding
# the repo root to PYTHONPATH lets 'import microsim' resolve, the OSC-
# recommended alternative to installing into ~/.local.
export PYTHONPATH="$microsimDir"

# Sanity check: which python are we actually using?
which python
python --version

# OpenMP threads: match ntasks for OpenMP jobs; harmless for serial jobs.
export OMP_NUM_THREADS=\$SLURM_NTASKS

endTime=\$SECONDS
echo "setup finished..."
echo "setup duration  \$(((\$endTime - \$startTime)/3600)) hr or \$(((\$endTime - \$startTime)/60)) min"
echo "simulation starts now..."

# microsim expects to be run from inside its source tree so its imports
# resolve. The tree is shared read-only; we cd into it but run the input
# file from \$TMPDIR and write output to \$TMPDIR.
cd "$microsimDir"
python \$TMPDIR/"$inputFile" > \$TMPDIR/"$outputFile"

echo "simulation finished..."

# ---- copy results back to the submit directory ----
cd \$TMPDIR

# remove the copied input file so it is not overwritten / re-copied
rm -f "$inputFile"

for ext in csv png; do
    if compgen -G "*.\$ext" > /dev/null; then
        cp *.\$ext \$SLURM_SUBMIT_DIR/
        echo "Successfully copied all .\$ext files."
    else
        echo "No .\$ext files were found to copy."
    fi
done

if [[ -f "$outputFile" ]]; then
    cp "$outputFile" \$SLURM_SUBMIT_DIR
    echo "Successfully copied output file: $outputFile"
else
    echo "ERROR: no output file $outputFile was found"
fi

date
endTime=\$SECONDS
echo "wall time  \$(((\$endTime - \$startTime)/3600)) hr or \$(((\$endTime - \$startTime)/60)) min"

EOF
